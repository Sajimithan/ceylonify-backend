# Database (per-service — copy the relevant URL into each service's .env as DATABASE_URL)
IDENTITY_DATABASE_URL=postgresql://ceylonify:ceylonify@localhost:5432/ceylonify_identity
LISTING_DATABASE_URL=postgresql://ceylonify:ceylonify@localhost:5432/ceylonify_listing
NOTIFICATION_DATABASE_URL=postgresql://ceylonify:ceylonify@localhost:5432/ceylonify_notification

# Firebase Admin (used by api-gateway and notification-service)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# FCM
FCM_SENDER_ID=your_sender_id

# Maps + Weather
OPENWEATHER_API_KEY=your_openweather_key

# AI
AI_ENABLED=true
AI_TIMEOUT_MS=8000
GEMINI_API_KEY=your_gemini_key
GEMINI_MODEL=gemini-1.5-flash
GROQ_API_KEY=your_groq_key
GROQ_MODEL=llama-3.1-8b-instant
